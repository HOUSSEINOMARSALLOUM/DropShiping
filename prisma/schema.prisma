generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  tasks     Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemTask {
  id          String   @id @default(cuid())
  type        String
  payload     Json?
  status      SystemTaskStatus @default(PENDING)
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Company {
  id          String    @id @default(cuid())
  name        String
  industry    String?
  website     String?
  contacts    Contact[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Contact {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  email       String    @unique
  phone       String?
  position    String?
  isVip       Boolean   @default(false)
  status      ContactStatus @default(LEAD)
  
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  
  notes       Note[]
  reminders   Reminder[]
  activities  Activity[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Note {
  id          String    @id @default(cuid())
  content     String
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reminder {
  id          String    @id @default(cuid())
  title       String
  dueDate     DateTime
  completed   Boolean   @default(false)
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Activity {
  id          String    @id @default(cuid())
  type        ActivityType
  description String
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Property {
  id          String    @id @default(cuid())
  title       String
  description String?
  price       Decimal   @db.Decimal(12, 2)
  address     String
  type        PropertyType
  status      PropertyStatus @default(AVAILABLE)
  
  beds        Int?
  baths       Int?
  sqft        Int?
  
  images      String[]  // Media upload preparation
  
  viewings    Viewing[]
  deals       Deal[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Viewing {
  id          String    @id @default(cuid())
  scheduledAt DateTime
  status      ViewingStatus @default(SCHEDULED)
  
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Deal {
  id          String    @id @default(cuid())
  value       Decimal   @db.Decimal(12, 2)
  status      DealStatus @default(PIPELINE)
  stage       String    @default("Negotiation") // e.g., "Negotiation", "Under Contract", "Closed"
  
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id])
  
  commission  Commission?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Commission {
  id          String    @id @default(cuid())
  amount      Decimal   @db.Decimal(12, 2)
  percentage  Decimal   @db.Decimal(5, 2)
  status      CommissionStatus @default(PENDING)
  
  dealId      String    @unique
  deal        Deal      @relation(fields: [dealId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Transaction {
  id          String    @id @default(cuid())
  amount      Decimal   @db.Decimal(12, 2)
  type        TransactionType
  category    String    // e.g., "Commission", "Operational", "Marketing"
  description String?
  reference   String?   // e.g., Wish Money Ref ID
  
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  
  dealId      String?
  deal        Deal?     @relation(fields: [dealId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Withdrawal {
  id          String    @id @default(cuid())
  amount      Decimal   @db.Decimal(12, 2)
  status      WithdrawalStatus @default(PENDING)
  method      String    // e.g., "Wish Money", "Bank Transfer"
  reference   String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Notification {
  id          String    @id @default(cuid())
  title       String
  message     String
  priority    NotificationPriority @default(MEDIUM)
  isRead      Boolean   @default(false)
  type        String    // e.g., "DEAL_ALERT", "CRM_REMINDER", "FINANCE_WAKEUP"
  
  link        String?   // URL to navigate when clicked
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AutomationRule {
  id          String    @id @default(cuid())
  name        String
  trigger     String    // e.g., "DEAL_CLOSED", "LEAD_CREATED"
  action      String    // e.g., "SEND_EMAIL", "CREATE_NOTIFICATION"
  config      Json?
  isEnabled   Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AIModelLog {
  id          String    @id @default(cuid())
  provider    String    // e.g., "OpenAI", "Anthropic"
  model       String
  promptTokens Int
  completionTokens Int
  cost        Decimal   @db.Decimal(10, 6)
  
  type        String    // e.g., "EXECUTIVE_BRIEFING", "LEAD_SCORING"
  
  createdAt   DateTime  @default(now())
}

model AIMemory {
  id          String    @id @default(cuid())
  key         String    @unique // e.g., "CONTACT_123_PREFERENCES"
  content     Json
  domain      String    // e.g., "CRM", "FINANCE"
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  action      String    // e.g., "CONTACT_UPDATE", "TRANSACTION_DELETE"
  entityType  String
  entityId    String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime  @default(now())
}

model SystemMetric {
  id          String    @id @default(cuid())
  name        String    // e.g., "REQUEST_LATENCY", "DATABASE_CONNECTIONS"
  value       Float
  unit        String?
  timestamp   DateTime  @default(now())
}

model StorageAsset {
  id          String    @id @default(cuid())
  key         String    @unique
  url         String
  fileName    String
  fileSize    Int
  mimeType    String
  provider    String    // e.g., "S3", "Vercel Blob"
  
  userId      String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Permission {
  id          String    @id @default(cuid())
  name        String    @unique
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         UserRole
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGENT
}

model ApiToken {
  id          String    @id @default(cuid())
  name        String
  token       String    @unique // Hashed token
  scopes      String[]  // e.g., ["crm:read", "finance:write"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  
  createdAt   DateTime  @default(now())
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String    // e.g., "Stripe", "Twilio"
  eventType   String
  payload     Json
  status      WebhookStatus @default(PENDING)
  error       String?
  
  createdAt   DateTime  @default(now())
  processedAt DateTime?
}

model SystemBackup {
  id          String    @id @default(cuid())
  key         String    @unique
  url         String
  size        Int
  status      BackupStatus @default(COMPLETED)
  
  createdAt   DateTime  @default(now())
}

enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

enum BackupStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum Role {
  USER
  ADMIN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum SystemTaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ContactStatus {
  LEAD
  PROSPECT
  CUSTOMER
  CHURNED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE_ADDED
  TASK_COMPLETED
  VIEWING_SCHEDULED
  DEAL_CREATED
  DEAL_CLOSED
  TRANSACTION_RECORDED
  AUTOMATION_TRIGGERED
  AI_INSIGHT_GENERATED
  SYSTEM_ARCHIVED
  INTEGRATION_SYNCED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  LAND
}

enum PropertyStatus {
  AVAILABLE
  UNDER_CONTRACT
  SOLD
  RENTED
}

enum ViewingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum DealStatus {
  PIPELINE
  WON
  LOST
}

enum CommissionStatus {
  PENDING
  PAID
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
